{
  "name": "openai-speech-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run tests",
    "test:coverage": "vitest run tests --coverage",
    "check": "tsc -p tsconfig.json --noEmit && vitest run tests",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@fastify/multipart": "^9.2.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.6.2",
    "prom-client": "^15.1.3",
    "yaml": "^2.8.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  }
}
